[Unit]
Description=CaiZiJieDi Flask SocketIO Service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/srv/CaiZiJieDi
EnvironmentFile=/srv/CaiZiJieDi/.env
ExecStart=/srv/CaiZiJieDi/.venv/bin/gunicorn -c /srv/CaiZiJieDi/gunicorn.conf.py app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
